@using System.Globalization
@model MVC.Models.VideoJuego
@{
    ViewData["Title"] = Model.Titulo;
    decimal precioFinal = Model.Precio;
    if (Model.Promocion != null)
    {
        precioFinal = Model.Precio - (Model.Precio * Model.Promocion.PorcentajeDescuento / 100);
    }
    string precioJs = precioFinal.ToString("F2", CultureInfo.InvariantCulture);
}

<nav style="margin-bottom:1.5rem;">
    <a asp-action="Catalogo" style="color:var(--muted); text-decoration:none; font-size:0.85rem;">
        <i class="fa-solid fa-chevron-left me-1"></i>Tienda
    </a>
    <span style="color:var(--border); margin:0 0.5rem;">/</span>
    <span style="color:var(--text); font-size:0.85rem;">@Model.Titulo</span>
</nav>

<div class="row g-4">
    <div class="col-md-5">
        <div style="border-radius:12px; overflow:hidden; border:1px solid var(--border); position:relative;">
            <img src="@Model.imagen" alt="@Model.Titulo" style="width:100%; display:block; object-fit:cover; min-height:380px;" />
            <div style="position:absolute; top:12px; left:12px;"><span class="badge-age">+@Model.EdadMinima</span></div>
        </div>
    </div>

    <div class="col-md-7">
        <span class="badge-category mb-3">@Model.Categoria?.Nombre</span>
        <h1 style="font-family:'Rajdhani',sans-serif; font-size:2.2rem; font-weight:700;">@Model.Titulo</h1>
        <p style="color:var(--muted); line-height:1.7;">@Model.Descripcion</p>

        <div style="background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:1.25rem; margin-bottom:1.5rem;">
            @if (Model.Promocion != null)
            {
                <div style="font-size:0.9rem; color:var(--muted); text-decoration:line-through;">$@Model.Precio</div>
                <div style="display:flex; align-items:center; gap:0.75rem;">
                    <span style="font-size:2rem; font-weight:700; color:var(--success);">$@precioFinal</span>
                    <span class="badge-promo">-@Model.Promocion.PorcentajeDescuento% OFF</span>
                </div>
            }
            else
            {
                <span style="font-size:2rem; font-weight:700; color:var(--success);">$@Model.Precio</span>
            }
        </div>

        <div class="d-flex gap-3 flex-wrap align-items-center">
            <div id="paypal-button-container" style="width: 250px;"></div>
            <a asp-action="Catalogo" class="btn-gs-secondary">Seguir explorando</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://www.paypal.com/sdk/js?client-id=AeaZjK1gAPZHegP4QyaWuoVYXmmuf9RWPVGUa0aHp1Rkxf83BzZj_p2T6xw4xNuCkgrR6RVyxyjszigp&currency=USD"></script>
    <script>
        paypal.Buttons({
            style: { color: 'gold', shape: 'rect', label: 'pay' },
            createOrder: function(data, actions) {
                const url = `/Account/CrearOrden?monto=@precioJs&nombreJuego=${encodeURIComponent('@Model.Titulo')}`;
                return fetch(url, { method: 'post' })
                    .then(res => res.json())
                    .then(orderData => orderData.id);
            },
            onApprove: function(data, actions) {
                return fetch('/Account/CapturarOrden', {
                    method: 'post',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `orderId=${data.orderID}&videoJuegoId=@Model.id&cantidad=1&total=@precioJs`
                }).then(res => res.json())
                  .then(details => {
                    if (details.success) {
                        alert('¡Compra realizada con éxito!');
                        window.location.href = '/Home/Catalogo';
                    }
                });
            }
        }).render('#paypal-button-container');
    </script>
}