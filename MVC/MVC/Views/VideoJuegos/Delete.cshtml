@model MVC.Models.VideoJuego
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@

<h2 class="btn btn-primary">Eliminar Videojuego</h2>

<h2 class="titulo-eliminar">¿Estás seguro que deseas eliminar este juego?</h2>

<div class="info-eliminar">
    <strong>@Model.Titulo</strong> - $@Model.Precio
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
