@model MVC.Models.VideoJuego

@* For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@

<h2 class="text-primary">Editar Videojuego</h2>
<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="id" />

    <div>
        <label class="form-label-custom">Titulo</label>
        <input asp-for="Titulo" class="form-control" />
        <span asp-validation-for="Titulo"></span>
    </div>
    <div>
        <label class="form-label-custom">Precio</label>
        <input asp-for="Precio" class="form-control" />
        <span asp-validation-for="Precio"></span>
    </div>
    <div>
        <label class="form-label-custom">Categoría</label>
        <input asp-for="Categoria" class="form-control" />
        <span asp-validation-for="Categoria"></span>
    </div>
    <div>
        <label class="form-label-custom">Descripción</label>
        <textarea asp-for="Descripcion" class="form-control"></textarea>
    </div>

    <div>
        <label class="form-label-custom">Imagen Actual</label><br />
        @if (!string.IsNullOrEmpty(Model.imagen))
        {
            <img src="@Model.imagen" width="120" class="img-thumbnail" />
        }
        else
        {
            <div class="alert alert-info" style="width: 120px; text-align: center;">
                Sin imagen
            </div>
        }
    </div>

    <div>
        <label class="form-label-custom">Nueva Imagen</label><br />
        <input type="file" name="ArchivoImagen" class="form-control" />
    </div>
    <button type="submit" class="btn btn-warning">Actualizar</button>
</form>