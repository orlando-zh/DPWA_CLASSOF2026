@{
    ViewData["Title"] = "Dashboard";
    var nombreUsuario = Context.Session.GetString("Usuario");
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Dashboard - Sistema</title>

    <script src="https://code.highcharts.com/highcharts.js"></script>
    <script src="https://code.highcharts.com/modules/exporting.js"></script>
    <script src="https://code.highcharts.com/modules/export-data.js"></script>
    <script src="https://code.highcharts.com/modules/accessibility.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.js" integrity="sha256-eKhayi8LEQwp4NKxN+CfCh+3qOVUtJn3QNZ0TciWLP4=" crossorigin="anonymous"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        /* VARIABLES DE DISEÑO GAMESTORE */
        :root {
            --accent: #f0a500;
            --surface: #1e2330;
            --surface2: #2a3040;
            --text: #e8eaf0;
            --muted: #a0a8b8;
            --success: #2ecc71;
        }

        body {
            /* Fondo oscuro principal para que no contraste feo con el layout general */
            background-color: #161922;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: var(--text);
        }

        /* REESTRUCTURACIÓN DEL DASHBOARD */
        .dashboard-container {
            padding: 30px;
        }

        /* Estilo para los selectores oscuros */
        .gs-select {
            background: var(--surface2);
            border: 1px solid #3a4255;
            color: var(--text);
            padding: 0.6rem 1rem;
            border-radius: 8px;
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.2s;
        }

            .gs-select:focus {
                border-color: var(--accent);
            }

        .chart-box {
            min-height: 400px;
            margin-top: 1rem;
        }

        .highcharts-background {
            fill: transparent !important;
        }
    </style>
</head>
<body>

    <div class="dashboard-container">

        <div class="gs-panel mb-4">
            <h4 style="font-family:'Rajdhani', sans-serif; font-weight:700; color:var(--text); margin-bottom:0.5rem;">
                Bienvenido, @(nombreUsuario ?? "Administrador") <span style="color:var(--accent);">👋</span>
            </h4>
            <p style="color: var(--muted); margin-bottom: 0;">
                Este es tu panel principal. Tu sesión ha sido validada correctamente con los datos de la base de datos.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="gs-panel h-100">
                    <select id="filtroCategoria" class="gs-select w-100 mb-3">
                        <option value="">Todas las categorías</option>
                        @foreach (var cat in ViewBag.Categorias)
                        {
                            <option value="@cat.idCategoria">@cat.Nombre</option>
                        }
                    </select>
                    <div id="container" class="chart-box"></div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="gs-panel h-100">
                    <div id="containerPrecioPromedio" class="chart-box"></div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Objeto de tema oscuro para forzar alto contraste en los textos y ejes de Highcharts
        const darkTheme = {
            chart: {
                backgroundColor: 'transparent',
                style: { fontFamily: "'Rajdhani', sans-serif" }
            },
            title: { style: { color: '#e8eaf0', fontSize: '16px', fontWeight: 'bold' } },
            xAxis: {
                labels: { style: { color: '#a0a8b8' } },
                lineColor: '#3a4255'
            },
            yAxis: {
                gridLineColor: '#2a3040',
                labels: { style: { color: '#a0a8b8' } },
                title: { style: { color: '#a0a8b8' } }
            },
            plotOptions: {
                series: {
                    states: {
                        hover: {
                            enabled: false 
                        },
                        inactive: {
                            enabled: false 
                        }
                    }
                }
            },
            legend: { itemStyle: { color: '#e8eaf0' }, itemHoverStyle: { color: '#e8eaf0' } },
            credits: { enabled: false }
        };

        function cargarGrafica(idCategoria = "") {
            $.get('/Account/ObtenerDatos', { idCategoria: idCategoria }, function (data) {
                var categorias = data.map(x => x.categoria);
                var totales = data.map(x => x.total);

                Highcharts.chart('container', Highcharts.merge(darkTheme, {
                    chart: { type: 'column' },
                    title: { text: 'Gráfica de videojuegos por categorías de zona digital' },
                    xAxis: { categories: categorias },
                    yAxis: { title: { text: 'Cantidad de Juegos' } },
                    tooltip: {
                        backgroundColor: '#2a3040',
                        style: { color: '#e8eaf0' },
                        formatter: function () {
                            return `<b>${this.key}</b><br/>Total de juegos: <b>${this.y}</b>`;
                        }
                    },
                    series: [{
                        name: 'Juegos',
                        data: totales,
                        color: '#f0a500' 
                    }]
                }));
            });
        }

        function cargarGraficaPrecio() {
            $.get('/Account/ObtenerPrecioPromedio', function (data) {
                Highcharts.chart('containerPrecioPromedio', Highcharts.merge(darkTheme, {
                    chart: { type: 'bar' },
                    title: { text: 'Precio Promedio por Categoría' },
                    xAxis: {
                        type: 'category',
                        title: { text: 'Categorías', style: { color: '#a0a8b8' } }
                    },
                    yAxis: {
                        title: { text: 'Precio Promedio ($)', style: { color: '#a0a8b8' } }
                    },
                    legend: { enabled: false },
                    tooltip: {
                        backgroundColor: '#2a3040',
                        style: { color: '#e8eaf0' },
                        pointFormat: 'Promedio: <b>${point.y:,.2f}</b>'
                    },
                    series: [{
                        name: 'Precio',
                        colorByPoint: true,
                        data: data
                    }]
                }));
            });
        }

        $(document).ready(function() {
            cargarGrafica();
            cargarGraficaPrecio();

            $('#filtroCategoria').change(function () {
                var id = $(this).val();
                cargarGrafica(id ? parseInt(id) : "");
            });
        });
    </script>
</body>
</html>