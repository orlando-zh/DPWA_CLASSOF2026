@model IEnumerable<MVC.Models.Categoria>
@{
    ViewData["Title"] = "Categorías";
}

<div class="gs-page-header">
    <h2 class="gs-page-title"><i class="fa-solid fa-tags me-2" style="color:var(--accent);"></i>Categorías</h2>
    <a asp-controller="Categorias" asp-action="Create" class="btn btn-primary">
        Crear nueva categoría
    </a>
</div>

<div class="gs-card">
    <table class="gs-table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Descripción</th>
                <th style="text-align:center;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="font-weight:600; color:var(--info);">@item.Nombre</td>
                    <td style="color:var(--muted); font-size:0.9rem;">@item.Descripcion</td>
                    <td style="text-align:center;">
                        <div class="d-flex gap-2 justify-content-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-gs-edit" style="font-size:0.8rem; padding:0.3rem 0.75rem;">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-gs-danger" style="font-size:0.8rem; padding:0.3rem 0.75rem;">
                                <i class="fa-solid fa-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="3" style="text-align:center; color:var(--muted); padding:2rem;">
                        No hay categorías registradas.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div style="margin-top:1rem;">
    <a asp-controller="VideoJuegos" asp-action="Inventario" class="btn-gs-secondary" style="font-size:0.85rem; padding:0.4rem 1rem;">
        <i class="fa-solid fa-chevron-left me-1"></i>Volver a Inventario
    </a>
</div>
