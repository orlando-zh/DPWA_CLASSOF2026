@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — Small Box</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            border: none;
            border-radius: 15px;
            width: 100%;
            max-width: 400px;
        }

        .btn-primary {
            background-color: #1b6ec2;
            border: none;
        }
    </style>
</head>
<body>
    <div class="card shadow-sm p-4">
        <div class="text-center mb-4">
            <i class="bi bi-box-seam text-primary fs-1"></i>
            <h4 class="fw-bold mt-2">Small <span style="color:#1b6ec2;">Box</span></h4>
            <p class="text-muted small">Inicio de sesión</p>
        </div>

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label small fw-medium">Correo electrónico</label>
                <input type="email" name="correo" class="form-control rounded-pill px-3" placeholder="correo@gmail.com" required>
            </div>
            <div class="mb-4">
                <label class="form-label small fw-medium">Contraseña</label>
                <input type="password" name="password" class="form-control rounded-pill px-3" placeholder="••••••••" required>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
            }

            <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 shadow-sm">
                Iniciar sesión
            </button>
        </form>
    </div>
</body>
</html>