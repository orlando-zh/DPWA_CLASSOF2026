@model IEnumerable<APPEnvios.Models.Envio>

<div class="d-flex justify-content-between mb-3">
    <h4>Lista de Envíos</h4>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4">Nuevo Envío</a>
</div>

<table class="table table-hover bg-white shadow-sm rounded-3 overflow-hidden">
    <thead class="table-light">
        <tr>
            <th>Destinatario</th>
            <th>Fecha</th>
            <th>Costo</th>
            <th>Estado</th>
            <th>Pago</th>
            <th>Sucursal</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-medium">@item.Destinatario?.Nombre</td>
                <td>@item.FechaEnvio.ToShortDateString()</td>
                <td>$@item.Costo</td>
                <td><span class="badge bg-info text-dark">@item.Estado?.NombreEstado</span></td>
                <td><span class="badge bg-secondary">@item.EstadoPago?.NombreEstado</span></td>
                <td>@item.Sucursal?.NombreSucursal</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.EnvioId" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                    <a asp-action="Delete" asp-route-id="@item.EnvioId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                </td>
            </tr>
        }
    </tbody>
</table>